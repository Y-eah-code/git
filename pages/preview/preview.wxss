page {
  background-color: #F8F4EF;
  height: 100vh;
}

/* ===== 步骤条 ===== */
.step-bar {
  display: flex;
  align-items: center;
  padding: 16px 20px 12px;
  background: #FFFFFF;
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.step-circle {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #E8E0D8;
  color: #999;
  font-size: 13px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.step-item.active .step-circle {
  background: #8B6B4D;
  color: #FFFFFF;
}
.step-label {
  font-size: 11px;
  color: #999;
}
.step-item.active .step-label {
  color: #8B6B4D;
}
.step-line {
  flex: 1;
  height: 2px;
  background: #E8E0D8;
  margin: 0 6px;
  margin-bottom: 18px;
}
.step-line.active {
  background: #8B6B4D;
}

/* ===== 预览区域 ===== */
.preview-area {
  width: 100%;
  height: 420px;
  background: #FFFFFF;
  margin: 12px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 30px;
}
.upload-icon {
  font-size: 56px;
}
.upload-title {
  font-size: 18px;
  font-weight: bold;
  color: #3D2B1F;
}
.upload-desc {
  font-size: 13px;
  color: #999;
}
.preview-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.preview-canvas {
  width: 100%;
  height: 100%;
}

/* ===== 操作区 ===== */
.action-area {
  flex: 1;
  padding: 0 16px;
  display: flex;
  flex-direction: column;
}
.action-section {
  margin-bottom: 14px;
}
.section-header {
  margin-bottom: 8px;
}
.section-title {
  font-size: 15px;
  font-weight: bold;
  color: #3D2B1F;
}

/* ===== 画框横向滚动 ===== */
.frame-scroll {
  white-space: nowrap;
}
.frame-list {
  display: inline-flex;
  gap: 12px;
  padding: 4px 0;
}
.frame-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  background: #FFFFFF;
  border-radius: 10px;
  border: 2px solid transparent;
  transition: all 0.2s;
  min-width: 70px;
}
.frame-item.selected {
  border-color: #8B6B4D;
  box-shadow: 0 2px 12px rgba(139,107,77,0.2);
}
.frame-color {
  width: 50px;
  height: 50px;
  border-radius: 8px;
  border: 1px solid #E8E0D8;
}
.frame-name {
  font-size: 12px;
  color: #5A4A3A;
  white-space: normal;
  text-align: center;
  line-height: 1.2;
}

/* ===== 卡纸横向滚动 ===== */
.mat-scroll {
  white-space: nowrap;
}
.mat-list {
  display: inline-flex;
  gap: 12px;
  padding: 4px 0;
}
.mat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  background: #FFFFFF;
  border-radius: 10px;
  border: 2px solid transparent;
  transition: all 0.2s;
  min-width: 60px;
}
.mat-item.selected {
  border-color: #8B6B4D;
  box-shadow: 0 2px 12px rgba(139,107,77,0.2);
}
.mat-color {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid #E8E0D8;
}
.mat-name {
  font-size: 12px;
  color: #5A4A3A;
}

/* ===== 底部按钮 ===== */
.bottom-actions {
  padding: 12px 0 30px;
  margin-top: auto;
}
.btn-next {
  background: linear-gradient(135deg, #8B6B4D, #6B4F3A);
  color: #FFFFFF;
  padding: 14px;
  border-radius: 12px;
  text-align: center;
  font-size: 16px;
  font-weight: bold;
}
.btn-group {
  display: flex;
  gap: 12px;
}
.btn-save {
  flex: 1;
  background: #F0EBE3;
  color: #5A4A3A;
  padding: 14px;
  border-radius: 12px;
  text-align: center;
  font-size: 15px;
  font-weight: 500;
}
.btn-order {
  flex: 1.5;
  background: linear-gradient(135deg, #8B6B4D, #6B4F3A);
  color: #FFFFFF;
  padding: 14px;
  border-radius: 12px;
  text-align: center;
  font-size: 16px;
  font-weight: bold;
}