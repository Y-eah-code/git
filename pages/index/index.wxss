/* ========== 全局 ========== */
page {
  background-color: #F8F4EF;
  padding-bottom: 20px;
}

/* ========== 顶部品牌栏 ========== */
.brand-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px 12px;
  background: linear-gradient(135deg, #8B6B4D, #6B4F3A);
}
.brand-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.brand-icon {
  font-size: 32px;
  width: 44px;
  height: 44px;
  background: rgba(255,255,255,0.15);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.brand-text {
  display: flex;
  flex-direction: column;
}
.brand-name {
  font-size: 20px;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 2px;
}
.brand-slogan {
  font-size: 11px;
  color: rgba(255,255,255,0.7);
  margin-top: 2px;
}
.brand-right {
  width: 40px;
  height: 40px;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-phone {
  font-size: 20px;
}

/* ========== Banner ========== */
.hero-section {
  padding: 14px 16px 0;
}
.hero-swiper {
  width: 100%;
  height: 150px;
  border-radius: 16px;
  overflow: hidden;
}
.hero-slide {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 20px;
}
.hero-title {
  font-size: 28px;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4px;
}
.hero-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  margin-top: 6px;
  letter-spacing: 1px;
}

/* ========== 核心入口 ========== */
.entry-section {
  padding: 16px 16px 0;
}
.entry-card {
  background: linear-gradient(135deg, #C4A882, #B8957A);
  border-radius: 16px;
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  box-shadow: 0 4px 16px rgba(139,107,77,0.3);
}
.entry-icon-wrap {
  width: 48px;
  height: 48px;
  background: rgba(255,255,255,0.25);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.entry-icon-big {
  font-size: 26px;
}
.entry-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.entry-title {
  font-size: 17px;
  font-weight: bold;
  color: #FFFFFF;
}
.entry-desc {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  margin-top: 2px;
}
.entry-arrow {
  font-size: 28px;
  color: rgba(255,255,255,0.6);
}

/* ========== 快捷功能 ========== */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 16px 16px 0;
  background: #F8F4EF;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 10px 20px;
}
.quick-icon {
  font-size: 28px;
}
.quick-label {
  font-size: 12px;
  color: #5A4A3A;
}

/* ========== 门店信息 ========== */
.store-section {
  padding: 10px 16px 0;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0 8px;
}
.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #3D2B1F;
}
.section-more {
  font-size: 13px;
  color: #B8957A;
}
.store-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 14px 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.store-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 6px 0;
}
.store-icon {
  font-size: 16px;
  width: 22px;
  flex-shrink: 0;
}
.store-text {
  font-size: 14px;
  color: #5A4A3A;
  line-height: 1.5;
}

/* ========== 案例展示 ========== */
.cases-section {
  padding: 0 16px 30px;
}
.cases-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.case-item {
  background: #FFFFFF;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.case-image {
  width: 100%;
  height: 90px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.case-emoji {
  font-size: 40px;
}
.case-name {
  display: block;
  padding: 10px 12px 12px;
  font-size: 13px;
  color: #3D2B1F;
  text-align: center;
  font-weight: 500;
}