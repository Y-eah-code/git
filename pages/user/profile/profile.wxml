<view class="profile-container">

<!-- 用户卡片 - 未登录状态 -->
<view class="user-card" wx:if="{{!userInfo.nickName}}">
  <view class="login-avatar">🧑‍🎨</view>
  <view class="login-info">
    <!-- 用 button 包裹文字，而不是 bindtap -->
    <button class="login-btn-custom" open-type="getUserInfo" bindgetuserinfo="getUserInfo">
      立即登录 >
    </button>
    <text class="login-sub">登录解锁更多装裱样式</text>
  </view>
</view>

<!-- 用户卡片 - 已登录状态 -->
<view class="user-card" wx:else>
  <view class="user-avatar">
    <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}"></image>
    <text wx:else>🧑‍🎨</text>
  </view>
  <view class="login-info">
    <text class="login-greeting">HI，{{userInfo.nickName}}</text>
    <view class="user-phone" bindtap="getPhoneNumber">{{userInfo.phone || '点击绑定手机号'}}</view>
    <text class="login-sub">已解锁全部装裱样式</text>
  </view>
  <view class="user-badge">已登录</view>
</view>

<!-- 订单统计 -->
<view class="stats-card">
  <view class="stat-item" bindtap="goToOrders">
    <view class="stat-number">{{allCount}}</view>
    <view class="stat-label">全部</view>
  </view>
  <view class="stat-divider"></view>
  <view class="stat-item" bindtap="goToOrders">
    <view class="stat-number pending">{{pendingCount}}</view>
    <view class="stat-label">待确认</view>
  </view>
  <view class="stat-divider"></view>
  <view class="stat-item" bindtap="goToOrders">
    <view class="stat-number making">{{makingCount}}</view>
    <view class="stat-label">制作中</view>
  </view>
  <view class="stat-divider"></view>
  <view class="stat-item" bindtap="goToOrders">
    <view class="stat-number done">{{doneCount}}</view>
    <view class="stat-label">已完成</view>
  </view>
</view>

<!-- 功能菜单 -->
<view class="menu-card">
  <view class="menu-item" bindtap="goToOrders">
    <view class="menu-icon">📋</view>
    <view class="menu-label">我的订单</view>
    <view class="menu-arrow">›</view>
  </view>
  <view class="menu-divider"></view>
  <view class="menu-item" bindtap="goToWorks">
    <view class="menu-icon">🎨</view>
    <view class="menu-label">我的作品库</view>
    <view class="menu-arrow">›</view>
  </view>
  <view class="menu-divider"></view>
  <view class="menu-item" bindtap="goToStore">
    <view class="menu-icon">🏠</view>
    <view class="menu-label">门店信息</view>
    <view class="menu-arrow">›</view>
  </view>
  <view class="menu-divider"></view>
  <view class="menu-item" bindtap="callPhone">
    <view class="menu-icon">📞</view>
    <view class="menu-label">联系店家</view>
    <view class="menu-arrow">›</view>
  </view>
  <view class="menu-divider"></view>
  <view class="menu-item danger" bindtap="clearData">
    <view class="menu-icon">🗑️</view>
    <view class="menu-label">清除预览数据</view>
    <view class="menu-arrow">›</view>
  </view>
</view>

<!-- 门店信息 -->
<view class="store-card">
  <view class="store-title">🏠 装裱大师 · 门店</view>
  <view class="store-row"><text>📍</text><text>山西省临汾市尧都区鼓楼北王麻子巷福强画院点睛阁</text></view>
  <view class="store-row"><text>🕐</text><text>9:00 - 18:00（周一至周日）</text></view>
  <view class="store-row"><text>📞</text><text class="store-phone" bindtap="callPhone">189-0357-8088</text></view>
</view>

<!-- 底部 -->
<view class="footer">
  <text class="footer-text">装裱大师 V1.0</text>
</view>
</view>