/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.empty-icon {
  font-size: 60px;
}
.empty-text {
  font-size: 18px;
  font-weight: bold;
  color: #3D2B1F;
  margin-top: 12px;
}
.empty-desc {
  font-size: 14px;
  color: #999;
  margin-top: 6px;
}