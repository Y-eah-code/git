/* 顶部状态切换 */
.order-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 0;
  position: relative;
}

.tab-item.active {
  color: #8B6B4D;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #8B6B4D;
  border-radius: 4rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.order-shop {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.order-status.pending {
  color: #E6A23C;
  background: #FDF6EC;
}

.order-status.making {
  color: #409EFF;
  background: #ECF5FF;
}

.order-status.done {
  color: #67C23A;
  background: #F0F9EB;
}

/* 订单内容 */
.order-body {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 20rpx;
}

.order-preview {
  width: 100rpx;
  height: 100rpx;
  background: #f5f0eb;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.order-detail {
  flex: 1;
}

.order-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.order-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.order-price {
  text-align: right;
}

.order-price .price {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.order-price .count {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #f5f5f5;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.order-actions button {
  font-size: 24rpx;
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  background: none;
  border: 2rpx solid #ddd;
  color: #666;
  line-height: 1.6;
}

.order-actions button::after {
  border: none;
}

.btn-cancel {
  border-color: #F56C6C !important;
  color: #F56C6C !important;
}

.btn-reorder {
  border-color: #8B6B4D !important;
  color: #8B6B4D !important;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.btn-go-shop {
  margin-top: 40rpx;
  background: #8B6B4D;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}
.btn-go-shop::after {
  border: none;
}