<!-- 顶部状态切换 -->
<view class="order-tabs">
  <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
    <text>全部</text>
  </view>
  <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
    <text>待接单</text>
  </view>
  <view class="tab-item {{currentTab === 'making' ? 'active' : ''}}" bindtap="switchTab" data-tab="making">
    <text>制作中</text>
  </view>
  <view class="tab-item {{currentTab === 'done' ? 'active' : ''}}" bindtap="switchTab" data-tab="done">
    <text>已完成</text>
  </view>
</view>

<!-- 订单列表 -->
<view class="order-list">
  <!-- 有订单时 -->
  <view class="order-card" wx:for="{{filteredOrders}}" wx:key="id" wx:for-item="order">
    <!-- 订单头部 -->
    <view class="order-header">
      <text class="order-shop">🖼️ 福强画院点睛阁</text>
      <text class="order-status {{order.status}}">{{order.statusText}}</text>
    </view>
    
    <!-- 订单内容 -->
    <view class="order-body">
      <view class="order-preview">
        <text class="order-emoji">{{order.emoji || '🎨'}}</text>
      </view>
      <view class="order-detail">
        <text class="order-name">{{order.productName || '装裱作品'}}</text>
        <text class="order-spec">{{order.spec || '默认规格'}}</text>
      </view>
      <view class="order-price">
        <text class="price">¥{{order.totalPrice || '0.00'}}</text>
        <text class="count">x{{order.quantity || 1}}</text>
      </view>
    </view>
    
    <!-- 订单底部 -->
    <view class="order-footer">
      <text class="order-time">{{order.createTime}}</text>
      <!-- 不同状态显示不同按钮 -->
      <view class="order-actions">
        <button wx:if="{{order.status === 'pending'}}" class="btn-cancel" bindtap="cancelOrder" data-id="{{order.id}}">取消订单</button>
        <button wx:if="{{order.status === 'done'}}" class="btn-reorder" bindtap="reOrder" data-id="{{order.id}}">再来一单</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredOrders.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-desc">去首页挑选喜欢的装裱作品吧</text>
    <button class="btn-go-shop" bindtap="goToIndex">去逛逛</button>
  </view>
</view>