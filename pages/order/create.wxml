<view class="container">
  <!-- 订单预览 -->
  <view class="preview-card">
    <view class="preview-image" style="background: #E8DDD0;">
      <text class="preview-emoji">🖼️</text>
    </view>
    <view class="preview-info">
      <text class="preview-name">待上传作品</text>
      <text class="preview-frame">画框：未选择</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <view class="section-title">📝 作品信息</view>
    
    <view class="form-item">
      <text class="form-label">作品名称</text>
      <input class="form-input" placeholder="如：兰亭序临摹" />
    </view>
    
    <view class="form-row">
      <view class="form-item half">
        <text class="form-label">宽度 (cm)</text>
        <input class="form-input" type="digit" placeholder="0" />
      </view>
      <view class="form-item half">
        <text class="form-label">高度 (cm)</text>
        <input class="form-input" type="digit" placeholder="0" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">装裱方式</text>
      <view class="radio-group">
        <view class="radio-item">
          <view class="radio-box"></view>
          <text>轴裱</text>
        </view>
        <view class="radio-item active">
          <view class="radio-box checked"></view>
          <text>框裱</text>
        </view>
        <view class="radio-item">
          <view class="radio-box"></view>
          <text>镜框</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">特殊需求</text>
      <textarea class="form-textarea" placeholder="如：急用、金色卡纸等" />
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">📦 配送信息</view>
    
    <view class="form-item">
      <text class="form-label">收货地址</text>
      <input class="form-input" placeholder="请输入详细地址" />
    </view>
    
    <view class="form-row">
      <view class="form-item half">
        <text class="form-label">联系人</text>
        <input class="form-input" placeholder="姓名" />
      </view>
      <view class="form-item half">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="手机号" />
      </view>
    </view>
  </view>

  <!-- 底部固定 -->
  <view class="bottom-bar">
    <view class="price-info">
      <text class="price-label">预估价格</text>
      <text class="price-number">¥0.00</text>
    </view>
    <view class="submit-btn">提交订单</view>
  </view>
</view>